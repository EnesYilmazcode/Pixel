# Frontend env template. Vite reads env from this (frontend/) directory.
# Copy to frontend/.env.local and fill in. .env.local is git-ignored.

# Backend base URL (the Vite dev proxy already forwards /predict /edit /agents here).
VITE_API_BASE=http://localhost:8000

# Clerk publishable key (auth is optional — app boots without it; see main.tsx guard).
VITE_CLERK_PUBLISHABLE_KEY=
