# Copy to .env and fill in real values. .env is git-ignored — NEVER commit real keys.

# --- Google Gemini (image edit + agent reasoning) ---
GEMINI_API_KEY=

# --- Pinecone (competitor-ad memory / RAG) ---
PINECONE_API_KEY=
PINECONE_INDEX=pixel-ads

# --- LangSmith (tracing + attention_score chart). Optional: no-op if unset ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=pixel

# --- Frontend -> backend (Vite dev proxy target) ---
VITE_API_BASE=http://localhost:8000